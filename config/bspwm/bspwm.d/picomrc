PICOM_DIR="$HOME/.config/bspwm/bspwm.d/picom"

# Restart picom
pkill -x picom 2>/dev/null
sleep 0.1
picom --config "$PICOM_DIR/picom.conf" &

echo "picom restarted — $PICOM_DIR/picom.conf"

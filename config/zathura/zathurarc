# --- Recolor (dark mode) ---
set recolor                  true
set recolor-keephue          false
set recolor-darkcolor        "#FFFFFF"
set recolor-lightcolor       "#2d333f"

# --- Appearance ---
set font                     "JetBrains Mono 11"
set default-bg               "#2d333f"
set default-fg               "#FFFFFF"
set statusbar-bg             "#252a34"
set statusbar-fg             "#5e81ac"
set inputbar-bg              "#252a34"
set inputbar-fg              "#88c0d0"
set completion-bg            "#2d333f"
set completion-fg            "#FFFFFF"
set notification-bg          "#2d333f"
set notification-fg          "#FFFFFF"
set notification-error-bg    "#2d333f"
set notification-error-fg    "#FF0000"
set notification-warning-bg  "#2d333f"
set notification-warning-fg  "#00FFFF"

# --- Behaviour ---
set selection-clipboard      clipboard
set scroll-step              25
set zoom-step                5
set render-loading           true

# --- Arrow key navigation ---
map <Up>    scroll up
map <Down>  scroll down
map <Left>  navigate previous
map <Right> navigate next

map <S-Left>  scroll full-left
map <S-Right> scroll full-right
